 * App Settings Model
 * Stores configurable settings for the application
 * Admin can update these without code changes
 */

export interface AppSettingDoc extends Document {
    key: string;
    value: any;
    description: string;
    category: 'rewards' | 'notifications' | 'limits' | 'general';
    updatedBy?: string;
    createdAt: Date;
    updatedAt: Date;
}

