        {/* Additional Details */}
        <div className="grid md:grid-cols-2 gap-6 mb-8">
          {/* Suitable For */}
          <Card className="border-2">
            <CardHeader>
              <CardTitle className="flex items-center gap-2">
                <CheckCircle className="h-5 w-5 text-chart-1" />
                {t('dogDetails.suitableFor')}
