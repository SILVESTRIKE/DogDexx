<file path="backend/src/scripts/verify_cloudinary_access.ts">
import dotenv from 'dotenv';
import path from 'path';
// Load env before imports that might use it
dotenv.config({ path: path.join(__dirname, '../../.env') });

import { uploadToCloudinary } from '../utils/media.util';
import axios from 'axios';
import { cloudinary } from '../config/cloudinary.config';

const runVerification = async () => {
    console.log("🔍 Starting Cloudinary Security Verification...");
    console.log("   - CLOUD_NAME:", process.env.CLOUD_NAME_CLOUDINARY ? "OK" : "MISSING");
    console.log("   - API_KEY:", process.env.API_KEY_CLOUDINARY ? "OK" : "MISSING");
    console.log("   - API_SECRET:", process.env.API_SECRET_CLOUDINARY ? "OK" : "MISSING");

    const dummyBuffer = Buffer.from("R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7", "base64"); // 1x1 Pixel GIF

    try {
        // 1. Verify Public Access (Avatars)
        console.log("\n1️⃣  Testing Public Access (Avatars)...");
        const publicUpload = await uploadToCloudinary(dummyBuffer, 'avatars', 'image', 'public');
        console.log(`   - Uploaded to public folder: ${publicUpload.public_id}`);
        console.log(`   - URL: ${publicUpload.secure_url}`);

        try {
            await axios.get(publicUpload.secure_url);
            console.log("   ✅ Public Image is ACCESSIBLE (Expected)");
        } catch (error: any) {
            console.error("   ❌ Public Image is INACCESSIBLE (Unexpected)", error.message);
        }

        // 2. Verify Private Access (Predictions) - Signed URL
        console.log("\n2️⃣  Testing Private Access (Predictions)...");
        // Force 'private' access mode to test the logic
        const privateUpload = await uploadToCloudinary(dummyBuffer, 'predictions', 'image', 'private');
        console.log(`   - Uploaded to private folder: ${privateUpload.public_id}`);

        // Generate Signed URL manually to verify `transformPaths` logic would work
        // Using environment variables directly to ensure we can generate signature
        const signedUrl = cloudinary.url(privateUpload.public_id, {
            type: 'authenticated',
            sign_url: true,
            secure: true,
            auth_token: {
                key: process.env.API_SECRET_CLOUDINARY,
                duration: 3600
            }
        });

        console.log(`   - Signed URL: ${signedUrl}`);

        try {
            await axios.get(signedUrl);
            console.log("   ✅ Private Image (Signed) is ACCESSIBLE (Expected)");
        } catch (error: any) {
            console.error("   ❌ Private Image (Signed) is INACCESSIBLE (Unexpected)", error.message);
        }

        // 3. Verify Private Access - Unsigned / Invalid
        console.log("\n3️⃣  Testing Unauthorized Access...");
        // Construct an unsigned URL for the authenticated resource
        const unsignedUrl = `https://res.cloudinary.com/${process.env.CLOUD_NAME_CLOUDINARY}/image/authenticated/${privateUpload.public_id}`;
        console.log(`   - Unsigned URL: ${unsignedUrl}`);

        try {
            await axios.get(unsignedUrl);
            console.log("   ❌ Unsigned Private Image is ACCESSIBLE (Security Failure!)");
        } catch (error: any) {
            if (error.response && [401, 403, 404].includes(error.response.status)) {
                console.log(`   ✅ Unsigned Private Image is BLOCKED: ${error.response.status} (Expected)`);
            } else {
                console.error("   ❓ Unexpected Error code:", error.message);
            }
        }

        // Cleanup
        console.log("\n🧹 Cleaning up test resources...");
        await cloudinary.uploader.destroy(publicUpload.public_id);
        await cloudinary.uploader.destroy(privateUpload.public_id, { type: 'authenticated' });
        console.log("   - Cleanup complete.");

    } catch (err) {
        console.error("Verification Script Failed:", err);
    }
};

runVerification();
</file>

