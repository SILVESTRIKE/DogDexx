  id: string
  title: string
  description: string
  icon: string
  requiredCount: number
  unlocked: boolean
  unlockedAt: string | null
}

interface AchievementsData {
  stats: {
    totalAchievements: number
    totalBreeds: number
    unlockedAchievements: number
    totalCollected: number
