<file path="backend/src/utils/test_legacy_path.ts">
import dotenv from 'dotenv';
import path from 'path';
import { cloudinary } from '../config/cloudinary.config';
import { transformMediaURLs } from './media.util';

dotenv.config({ path: path.join(__dirname, '../../.env') });

const runTest = async () => {
    console.log("Testing Legacy Path Transformation...");

    const mockReq = {
        protocol: 'http',
        get: () => 'localhost:3000'
    } as any;

    const legacyDoc = {
        _id: "68ea006c866385d5053e38ac",
        breed: "Pug",
        mediaPath: "public/dog-data-img/pug.jpg"
    };

    console.log("Original Doc:", legacyDoc);

    const transformedDoc = transformMediaURLs(mockReq, legacyDoc);

    console.log("Transformed Doc:", transformedDoc);
    const generatedUrl = transformedDoc.mediaUrl;
    console.log("Generated URL:", generatedUrl);

    if (generatedUrl && generatedUrl.includes('cloudinary.com') && generatedUrl.includes('s--')) {
        console.log("PASS: URL is a Cloudinary Signed URL.");
    } else {
        console.error("FAIL: URL is not formatted correctly or missing signature.");
        // Log manual generation attempt to isolate issue
        const manualPublicId = 'public/dog-data-img/pug';
        try {
            const manualUrl = cloudinary.url(manualPublicId, {
                resource_type: 'image',
                type: 'authenticated',
                sign_url: true,
                secure: true,
            });
            console.log("Manual URL generation check:", manualUrl);
        } catch (e) {
            console.error("Manual URL generation failed:", e);
        }
    }
};

runTest();
</file>

<file path="backend/src/utils/test_security.ts">
import dotenv from 'dotenv';
import path from 'path';
import fs from 'fs';
dotenv.config({ path: path.join(__dirname, '../../.env') });

import { uploadToCloudinary } from './media.util';
import { cloudinary } from '../config/cloudinary.config';
import axios from 'axios';

const logFile = path.join(__dirname, 'test_result.log');
// clear log file
fs.writeFileSync(logFile, '');

const log = (msg: string) => {
    console.log(msg);
    fs.appendFileSync(logFile, msg + '\n');
};

const runTest = async () => {
    log("Starting Cloudinary Security Test...");

    // 1. Create a dummy image buffer (small red dot)
    const base64Image = "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mP8z8BQDwAEhQGAhKmMIQAAAABJRU5ErkJggg==";
    const buffer = Buffer.from(base64Image, 'base64');

    try {
        // 2. Upload with default settings (should be 'authenticated' now)
        log("Uploading test image...");
        // folder: 'test_security'
        const result = await uploadToCloudinary(buffer, 'test_security', 'image');
        log(`Upload result public_id: ${result.public_id}`);
        log(`Upload result access_mode: ${result.access_mode}`);
        log(`Upload result type: ${result.type}`);

        if (result.type !== 'authenticated') {
            log(`FAIL: Uploaded image type is NOT authenticated! It is: ${result.type}`);
        } else {
            log("PASS: Uploaded image type is authenticated.");
        }

        // 3. Verify access control
        const rawUrl = result.secure_url;
        log(`Testing Raw URL: ${rawUrl}`);

        try {
            await axios.get(rawUrl);
            log("FAIL: Raw URL access succeeded! (Should be 401/404)");
        } catch (error: any) {
            if (error.response && (error.response.status === 401 || error.response.status === 403 || error.response.status === 404)) {
                log(`PASS: Raw URL access failed as expected with status ${error.response.status}`);
            } else {
                log(`FAIL or Unexpected Error: Raw URL access failed with status ${error.response ? error.response.status : error.message}`);
            }
        }

        // 4. Generate Signed URL manually
        const signedUrl = cloudinary.url(result.public_id, {
            resource_type: 'image',
            type: 'authenticated',
            sign_url: true,
            secure: true
        });

        log(`Testing Signed URL: ${signedUrl}`);

        try {
            const responseSigned = await axios.get(signedUrl);
            if (responseSigned.status === 200) {
                log("PASS: Signed URL access succeeded.");
            } else {
                log(`FAIL: Signed URL access failed! Status: ${responseSigned.status}`);
            }
        } catch (e: any) {
            log(`FAIL: Signed URL access error: ${e.message}`);
        }

        // Cleanup
        await cloudinary.uploader.destroy(result.public_id, { type: 'authenticated' });
        log("Cleanup complete.");

    } catch (error) {
        log(`Test execution failed: ${error}`);
    }
};

runTest();
</file>

