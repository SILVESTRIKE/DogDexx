    fetchAchievements()
  }, [locale])

  // Sắp xếp thành tích: đã mở khóa lên trước, sau đó đến chưa mở khóa
  const sortedAchievements = useMemo(() => {
    if (!data?.achievements) return []
    return [...data.achievements].sort((a, b) => {
